# Переменные окружения бэкенда. Задавать в дашборде хостинга (Render → Environment),
# НЕ коммитить реальные значения в git.
BOT_TOKEN=ВСТАВЬ_НОВЫЙ_ТОКЕН_ПОСЛЕ_REVOKE
ADMIN_CHAT_ID=ВСТАВЬ_СВОЙ_CHAT_ID
WEB_APP_URL=https://relaxed-liger-2d17fd.netlify.app
# Публичный адрес самого бэка для /set_webhook. На Render подставляется
# автоматически (RENDER_EXTERNAL_URL) — переменную можно не задавать.
# PUBLIC_BASE_URL=https://arkhipova-psy-bot.onrender.com
# Гайд в канале (есть дефолты в коде — можно не задавать):
